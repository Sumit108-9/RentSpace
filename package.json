{
  "name": "furniture-rental-app",
  "version": "1.0.0",
  "description": "MERN Stack Furniture Rental Application",
  "scripts": {
    "dev": "concurrently \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
    "install-all": "cd backend && npm install && cd ../frontend && npm install",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "mongodb": "^7.2.0",
    "mongoose": "^9.5.0",
    "winston": "^3.19.0"
  }
}
